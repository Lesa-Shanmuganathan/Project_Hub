# Django Configuration
DEBUG=False
SECRET_KEY=your-super-secret-key-here-min-50-characters-recommended

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database (Render auto-sets this, but shown for reference)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Cloudinary (optional - for image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security (for Render production)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Local development (set to True locally, False in production)
# DEBUG=True
